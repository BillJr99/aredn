CONFIG_TARGET_ath79=y
CONFIG_TARGET_ath79_tiny=y
#
# EXPERIMENTAL: legacy Ubiquiti "XM" boards (8MB flash / 32MB RAM).
# These were "frozen" at the OLSR->Babel transition because they could not
# hold both routing stacks at once. 4.x is Babel-only, so a slimmed image
# fits again. Keeps Babel, ath9k wifi (incl. Part-15 via the global
# CONFIG_ATH_USER_REGD + 701-extended-spectrum patch) and WireGuard tunnels.
# Heavy/optional packages from common.config are turned off below to fit
# 8MB NOR and run in 32MB RAM. zram-swap is promoted into the image.
#
CONFIG_TARGET_DEVICE_ath79_tiny_DEVICE_ubnt_nanostation-m=y
CONFIG_TARGET_DEVICE_ath79_tiny_DEVICE_ubnt_nanostation-loco-m=y
CONFIG_TARGET_DEVICE_ath79_tiny_DEVICE_ubnt_bullet-m-ar7240=y
CONFIG_TARGET_DEVICE_ath79_tiny_DEVICE_ubnt_bullet-m-ar7241=y
CONFIG_TARGET_DEVICE_ath79_tiny_DEVICE_ubnt_picostation-m=y
CONFIG_TARGET_DEVICE_ath79_tiny_DEVICE_ubnt_nanobridge-m=y
CONFIG_TARGET_DEVICE_ath79_tiny_DEVICE_ubnt_airrouter=y
#
# RAM relief on 32MB boards (common.config has this as =m)
#
CONFIG_PACKAGE_zram-swap=y
#
# Drop heavy/optional packages (override the =y settings in common.config)
#
CONFIG_PACKAGE_prometheus-exporter=n
CONFIG_PACKAGE_iperf3=n
CONFIG_PACKAGE_socat=n
CONFIG_PACKAGE_inotifywait=n
CONFIG_PACKAGE_ethtool=n
CONFIG_PACKAGE_curl=n
CONFIG_PACKAGE_libcurl=n
CONFIG_PACKAGE_ATH_DEBUG=n
CONFIG_PACKAGE_ATH_SPECTRAL=n
CONFIG_PACKAGE_tc-full=n
CONFIG_PACKAGE_kmod-sched-cake=n
CONFIG_PACKAGE_ubi-utils=n
